---
import '../styles/globals.css';
import Analytics from '../components/Analytics.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'rinha2-back-end-python | Slow is Smooth. Smooth is Fast.',
  description = 'High-performance banking API for the Rinha de Backend challenge. Built with Python 3.14, Flask 3.1, and Gunicorn. Handles concurrent transactions under strict resource constraints (1.5 CPU, 550MB RAM).'
} = Astro.props;

const pageUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : `https://jonathanperis.github.io${Astro.url.pathname}`;
const baseUrl = import.meta.env.BASE_URL;
const faviconUrl = `${baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`}favicon.ico`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  'name': 'Rinha de Backend — Python',
  'description': description,
  'url': pageUrl,
  'codeRepository': 'https://github.com/jonathanperis/rinha2-back-end-python',
  'programmingLanguage': 'Python',
  'runtimePlatform': 'Python 3.14',
  'license': 'https://github.com/jonathanperis/rinha2-back-end-python/blob/main/LICENSE',
  'author': {
    '@type': 'Person',
    'name': 'Jonathan Peris',
    'url': 'https://jonathanperis.github.io/'
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <meta name="description" content={description} />
    <meta name="keywords" content="Python, Flask, Gunicorn, psycopg2, PostgreSQL, banking API, Rinha de Backend, performance, load testing" />
    <link rel="canonical" href={pageUrl} />
    <meta name="theme-color" content="#4B8BBE" />
    <link rel="icon" href={faviconUrl} sizes="any" />
    <link rel="shortcut icon" href={faviconUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="rinha2-back-end-python" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:creator" content="@jperis_silva" />

    <!-- JSON-LD Structured Data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <title>{title}</title>
    <Analytics />
  </head>
  <body>
    <div class="particles">
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
    </div>

    <div class="snake-dec snake-1"></div>
    <div class="snake-dec snake-2"></div>

    <slot />
  </body>
</html>
