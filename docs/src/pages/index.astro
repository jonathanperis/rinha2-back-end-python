---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/home/Navbar.astro';
import Hero from '@/components/home/Hero.astro';
import Dashboard from '@/components/home/Dashboard.astro';
import Footer from '@/components/home/Footer.astro';

const title = 'rinha2-back-end-python | Python Performance Benchmark';
const description = 'High-performance banking API for the Rinha de Backend challenge. Built with Python 3.14, Flask 3.1, and Gunicorn. Handles concurrent transactions under strict resource constraints (1.5 CPU, 550MB RAM).';
---

<BaseLayout title={title} description={description}>
  <Navbar />

  <main>
    <Hero />
    <Dashboard />
  </main>

  <Footer />
</BaseLayout>
