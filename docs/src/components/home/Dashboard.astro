---
import fs from 'node:fs';
import path from 'node:path';

const stressTestMetrics = [
  { value: '47k+', label: 'Requests/Second' },
  { value: '<50ms', label: 'P95 Latency' },
  { value: '99.9%', label: 'Success Rate' }
];

const reportsDir = path.join(process.cwd(), 'public/reports');
const allReports = fs.readdirSync(reportsDir)
  .filter(f => f.endsWith('.html'))
  .sort()
  .reverse();

function parseReportMeta(filename: string) {
  const match = filename.match(/(\d{4})(\d{2})(\d{2})(\d{2})(\d{2})(\d{2})/);
  if (!match) return { date: filename, time: '' };
  const [, year, month, day, hour, minute] = match;
  return {
    date: `${year}-${month}-${day}`,
    time: `${hour}:${minute}`,
  };
}

const recentReports = allReports.slice(0, 8).map(file => ({
  file,
  ...parseReportMeta(file),
}));
---

<section class="code-block">
  <pre><code><span class="keyword">class</span> ChallengeConstraints:
    <span class="comment"># System Topology</span>
    API_INSTANCES = <span class="string">2</span>
    LOAD_BALANCER = <span class="string">"Nginx"</span>
    DATABASE = <span class="string">"Postgres"</span>

    <span class="comment"># Resource Limits</span>
    MAX_CPU = <span class="string">1.5</span>
    MAX_RAM_MB = <span class="string">550</span>

    <span class="comment"># Goal</span>
    TARGET_REQUESTS = <span class="string">47000</span></code></pre>
</section>

<section class="features">
  <div class="card">
    <h3>Extreme Constraints</h3>
    <p>Limited to 1.5 CPU cores and 550MB RAM across the ENTIRE stack (2 APIs, 1 Nginx, 1 DB).</p>
  </div>
  <div class="card">
    <h3>High Throughput</h3>
    <p>Designed to handle intense Gatling load tests aiming for 47k+ successful financial transactions.</p>
  </div>
  <div class="card">
    <h3>Python Async</h3>
    <p>Leveraging asynchronous Python paradigms for non-blocking database and network operations.</p>
  </div>
</section>

<section class="stress-tests">
  <h3>⚡ Stress Test Results</h3>
  <p class="stress-intro">
    Validated under extreme load conditions using k6. The system maintains stable performance
    even when processing thousands of concurrent banking transactions.
  </p>

  <div class="stress-metrics">
    {stressTestMetrics.map(metric => (
      <div class="stress-metric">
        <span class="metric-value">{metric.value}</span>
        <span class="metric-label">{metric.label}</span>
      </div>
    ))}
  </div>

  <div class="stress-links">
    <a href="https://github.com/jonathanperis/rinha2-back-end-python/actions/workflows/main-release.yml" class="stress-link" target="_blank" rel="noopener noreferrer">
      <span>📊</span> View CI/CD Stress Tests
    </a>
    <a href="./docs/" class="stress-link">
      <span>📖</span> Documentation
    </a>
  </div>

  <div class="reports-section">
    <h4>📈 Historical Reports</h4>
    <div class="reports-grid">
      {recentReports.map(report => (
        <a href={`./reports/${report.file}`} class="report-link">
          <span class="report-date">{report.date}</span>
          <span class="report-time">{report.time}</span>
        </a>
      ))}
    </div>
    <p class="reports-note">{allReports.length} stress test runs archived • <a href="./reports/">View all reports →</a></p>
  </div>
</section>
